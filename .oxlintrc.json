{
  "$schema": "https://oxc.rs/schema/config.json",
  "excludeFiles": [
    "dist/**",
    ".output/**",
    "node_modules/**",
    ".nuxt/**",
    "coverage/**",
    "*.min.js"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "style": "warn",
    "pedantic": "off",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "warn",
    "eqeqeq": ["warn", "always"],
    "no-var": "warn",
    "prefer-const": "warn",
    "no-unused-vars": "warn"
  }
}
